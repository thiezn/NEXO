{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "effortLevel": "high",
  "permissions": {
    "allow": [
      "Bash(cargo *)",
      "Bash(xargs cat *)",
      "Bash(find *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(mkdir *)",
      "Bash(grep *)",
      "Bash(curl *)",
      "Bash(cat *)",
      "Bash(python3 -c *)",
      "Bash(| head *)",
