{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "effortLevel": "high",
  "permissions": {
    "allow": [
      "Bash(cargo:*)",
      "Bash(xargs cat:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "mcp__xcode",
      "Edit(.claude/**)",
      "Write(.claude/**)"
    ]
  },
  "defaultMode": "acceptEdits",
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  }
}
