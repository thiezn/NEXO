    ],
    "deny": [
      "WebFetch"
    ],
    "additionalDirectories": [
      "//Users/Mathijs.Mortimer/.cargo/registry",
      "//Users/Mathijs.Mortimer/.nexo",
    ]
  },
  "defaultMode": "acceptEdits",
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  }
}
